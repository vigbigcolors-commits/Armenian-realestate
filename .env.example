# ─── DATABASE ───────────────────────────────────────────────
POSTGRES_DB=smartestate
POSTGRES_USER=smartestate
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DATABASE_URL=postgresql://smartestate:CHANGE_THIS_STRONG_PASSWORD@postgres:5432/smartestate

# ─── REDIS ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── TELEGRAM BOT ───────────────────────────────────────────
# Получите у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# ─── AI: Google Gemini (бесплатный tier) ────────────────────
# Ключ: https://aistudio.google.com/apikey
AI_PROVIDER=gemini
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=

# ─── ПАРСЕР ─────────────────────────────────────────────────
# Задержка между запросами к сайту (секунды), не менее 2
PARSER_DELAY_SECONDS=3
# Сколько страниц парсить за один прогон
PARSER_MAX_PAGES=50
# Интервал запуска парсера (минуты)
PARSER_INTERVAL_MINUTES=180

# ─── API ────────────────────────────────────────────────────
SECRET_KEY=CHANGE_THIS_SECRET_KEY_FOR_JWT
API_BASE_URL=http://api:8000
SITE_URL=http://localhost:3001

# ─── ПЛАТЕЖИ (Idram / Ameriabank) ───────────────────────────
IDRAM_ACCOUNT_ID=
IDRAM_SECRET_KEY=
PAYMENT_SUCCESS_URL=https://yourdomain.am/payment/success
PAYMENT_FAIL_URL=https://yourdomain.am/payment/fail
